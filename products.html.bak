<body>
    <!-- Animated Background -->
    <div class="animated-background">
        <div class="clouds">
            <div class="cloud cloud-1"></div>
            <div class="cloud cloud-2"></div>
            <div class="cloud cloud-3"></div>
            <div class="cloud cloud-4"></div>
            <div class="cloud cloud-5"></div>
        </div>
        <div class="building-container">
            <div class="building building-1"></div>
            <div class="building building-2"></div>
            <div class="building building-3"></div>
            <div class="building building-4"></div>
            <div class="building building-5"></div>
            <div class="building building-6"></div>
            <div class="building building-7"></div>
            <div class="building building-8"></div>
        </div>
        <div class="particles">
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
            <div class="particle"></div>
        </div>
    </div>

    <!-- Scroll Progress -->
    <div class="scroll-progress" id="scrollProgress"></div>

    <!-- Scroll Building -->
    <div class="scroll-building" id="scrollBuilding"></div>

    <!-- Navigation -->
    <nav class="navbar">
        <div class="container">
            <div class="nav-brand">
                <a href="index.html" class="logo">
                    <img src="images/logo.png" alt="GreenFort Logo" class="logo-img">
                </a>
            </div>
            <button class="mobile-menu-btn" id="mobileMenuBtn">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <ul class="nav-menu" id="navMenu">
                <li><a href="index.html">Home</a></li>
                <li><a href="products.html" class="active">Products</a></li>
                <li><a href="index.html#about">About Us</a></li>
                <li><a href="index.html#testimonials">Testimonials</a></li>
                <li><a href="index.html#contact" class="btn-contact">Contact Us</a></li>
            </ul>
        </div>
    </nav>

    <!-- Products Hero -->
    <section class="products-hero reveal">
        <div class="container">
            <div class="products-hero-content">
                <h1>Our Products</h1>
                <p>Premium quality building materials for all your construction needs</p>
                <div class="breadcrumb">
                    <a href="index.html">Home</a>
                    <span>/</span>
                    <span>Products</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Products Filter -->
    <section class="products-filter">
        <div class="container">
            <div class="filter-buttons">
                <button class="filter-btn active" data-filter="all">All Products</button>
                <button class="filter-btn" data-filter="aac">AAC Blocks & Walls</button>
                <button class="filter-btn" data-filter="adhesives">Adhesives & Plasters</button>
                <button class="filter-btn" data-filter="decorative">Decorative</button>
                <button class="filter-btn" data-filter="windows">Steel Windows</button>
            </div>
        </div>
    </section>

